# Copy to .env and fill in values locally — never commit .env

DEBUG=false

# LLM (Validation, Recommendation, company extraction)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Web search (Discovery) — Tavily preferred, Firecrawl as fallback
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# Contact enrichment (Contact Agent) — mock fallback when unset
APOLLO_API_KEY=
